# Environment variables for the ChurnPredictionService
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ChurnPredictionService
APP_VERSION=1.0.0
ENV=development
DEBUG=false

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Restrict CORS in production: CORS_ORIGINS=["https://your-frontend.com"]
CORS_ORIGINS=["*"]

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ChurnPrediction
MLFLOW_MODEL_NAME=ChurnModel
MLFLOW_MODEL_STAGE=Production

# ── Model ─────────────────────────────────────────────────────────────────────
# Override to load a specific run: MODEL_URI=runs:/<run_id>/model
MODEL_URI=
CHURN_WINDOW_DAYS=30

# ── Batch ─────────────────────────────────────────────────────────────────────
BATCH_INPUT_PATH=data/users.csv
BATCH_OUTPUT_DIR=data/batch_results

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Risk thresholds ───────────────────────────────────────────────────────────
RISK_LOW_THRESHOLD=0.3
RISK_HIGH_THRESHOLD=0.7
